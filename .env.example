PORT=4001
CERT_PATH=certs/signing.crt
KEY_PATH=certs/signing.key
UPLOAD_DIR=uploads
ORG_NAME=Friends of Justin

# Direct OpenAI API (local/default)
# Optional behavioral auditor. Free2PA core does not require an LLM account.
# Bring your own OpenAI or OpenAI-compatible account:
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.6
OPENAI_BASE_URL=

# Or Azure OpenAI v1. Use AZURE_OPENAI_API_KEY locally; Azure App Service can
# use its system-assigned identity without storing a key.
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_DEPLOYMENT=free2pa-gpt-5-6
AZURE_OPENAI_API_KEY=

# Or install an auditor adapter module in this project and name it here.
# The module runs with this server's privileges; install only trusted code.
FREE2PA_AUDITOR_MODULE=
FREE2PA_AUDITOR_MODEL=
